---
import { getCollection, render } from 'astro:content';
import { getImage, Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Lightbox from '../../components/Lightbox.astro';
import { withBase, TIPO_LABEL } from '../../lib/utils';

export async function getStaticPaths() {
  const guitarras = await getCollection('guitarras');
  return guitarras.map((g) => ({ params: { slug: g.id }, props: { guitarra: g } }));
}

const { guitarra } = Astro.props;
const { nome, marca, modelo, tipo, anoAquisicao, fotos, extras, specs } = guitarra.data;
const { Content } = await render(guitarra);

const principais = [fotos.foto1, fotos.foto2, fotos.foto3, fotos.foto4];
const todas = [...principais, ...extras];

// Versões grandes para o lightbox
const grandes = await Promise.all(
  todas.map((f) => getImage({ src: f, width: 1800, format: 'webp', quality: 82 }))
);
const fotosLightbox = grandes.map((img, i) => ({
  src: img.src,
  alt:
    i < 4
      ? `Foto ${i + 1} da guitarra ${nome}`
      : `Foto extra ${i - 3} da guitarra ${nome}`,
}));

const marcaModelo = [marca, modelo].filter(Boolean).join(' ');

const specsLista: [string, string][] = (
  [
    ['Ano de aquisição', String(anoAquisicao)],
    ['Corpo', specs.corpo],
    ['Tampo', specs.tampo],
    ['Braço', specs.braco],
    ['Escala', specs.escala],
    ['Captadores', specs.captadores],
    ['País de origem', specs.pais],
    ['N.º de série', specs.numeroSerie],
  ] as [string, string | undefined][]
).filter((par): par is [string, string] => Boolean(par[1]));

const descricaoMeta = `${nome}${marcaModelo ? ` — ${marcaModelo}` : ''} · ${TIPO_LABEL[tipo]}, adquirida em ${anoAquisicao}.`;
const ogImage = Astro.site ? new URL(grandes[0]!.src, Astro.site).href : undefined;
---

<Base title={nome} description={descricaoMeta} ogImage={ogImage}>
  <nav class="voltar reveal" aria-label="Voltar">
    <a href={withBase('/')} class="voltar-link">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
        <path d="M14 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      Galeria
    </a>
  </nav>

  <header class="cabecalho">
    <p class="caption categoria reveal">
      <span class="categoria-tipo">{TIPO_LABEL[tipo]}</span>
      <span aria-hidden="true">·</span>
      <span>Adquirida em {anoAquisicao}</span>
    </p>
    <h1 class="reveal" style="--reveal-delay: 70ms">{nome}</h1>
    {
      marcaModelo && (
        <p class="marca-modelo text-secondary reveal" style="--reveal-delay: 140ms">
          {marcaModelo}
        </p>
      )
    }
  </header>

  {/* Mosaico das 4 fotos obrigatórias */}
  <section class="mosaico" aria-label={`Fotos principais da ${nome}`}>
    {
      principais.map((foto, i) => (
        <button
          class="mosaico-item reveal"
          style={`--reveal-delay: ${120 + i * 110}ms`}
          type="button"
          data-lightbox={i}
          aria-label={`Ampliar foto ${i + 1} da ${nome}`}
        >
          <Image
            src={foto}
            alt={`Foto ${i + 1} da guitarra ${nome}`}
            widths={[480, 800, 1200]}
            sizes={
              i === 0
                ? '(max-width: 820px) 94vw, 56vw'
                : '(max-width: 820px) 30vw, 36vw'
            }
            loading="eager"
            {...(i === 0 ? { 'transition:name': `foto-hero-${guitarra.id}` } : {})}
          />
        </button>
      ))
    }
  </section>

  <div class="conteudo">
    <section class="descricao reveal" aria-label="Descrição">
      <Content />
    </section>

    <aside class="specs-painel reveal" style="--reveal-delay: 90ms" aria-label="Especificações">
      <h3 class="specs-titulo">Ficha</h3>
      <dl class="specs">
        {
          specsLista.map(([rotulo, valor]) => (
            <div class="spec">
              <dt class="caption">{rotulo}</dt>
              <dd>{valor}</dd>
            </div>
          ))
        }
      </dl>
    </aside>
  </div>

  {
    extras.length > 0 && (
      <section class="extras" aria-label="Mais fotos">
        <h3 class="extras-titulo reveal">Mais Fotos</h3>
        <div class="extras-grelha">
          {extras.map((foto, i) => (
            <button
              class="extra reveal"
              style={`--reveal-delay: ${i * 90}ms`}
              type="button"
              data-lightbox={4 + i}
              aria-label={`Ampliar foto extra ${i + 1} da ${nome}`}
            >
              <Image
                src={foto}
                alt={`Foto extra ${i + 1} da guitarra ${nome}`}
                widths={[240, 420]}
                sizes="(max-width: 640px) 44vw, 200px"
                loading="lazy"
              />
            </button>
          ))}
        </div>
      </section>
    )
  }

  <div class="rodape-navegacao reveal">
    <a class="btn btn-secondary" href={withBase('/')}>Voltar à galeria</a>
  </div>

  <Lightbox fotos={fotosLightbox} />
</Base>

<style>
  .voltar {
    margin-bottom: var(--space-4);
  }

  .voltar-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }

  .voltar-link:hover {
    color: var(--text);
  }

  .cabecalho {
    margin-bottom: var(--space-5);
  }

  .categoria {
    display: flex;
    gap: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-secondary);
    margin-bottom: var(--space-2);
  }

  .categoria-tipo {
    color: var(--secondary);
    font-weight: 500;
  }

  .marca-modelo {
    font-size: 20px;
    margin-top: var(--space-2);
  }

  /* ---- Mosaico: foto 1 dominante + 3 secundárias ----
     O aspect-ratio no contentor dá altura definida às rows 1fr —
     sem ele, as fotos da coluna direita colapsariam para altura 0. */
  .mosaico {
    display: grid;
    grid-template-columns: 1.55fr 1fr;
    grid-template-rows: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-7);
    aspect-ratio: 4 / 3;
    max-height: 88vh;
  }

  .mosaico-item {
    padding: 0;
    border: 0;
    background: var(--cream);
    border-radius: 24px;
    overflow: clip;
    cursor: zoom-in;
    display: block;
    min-height: 0;
  }

  .mosaico-item:first-child {
    grid-row: 1 / -1;
  }

  .mosaico-item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: scale 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mosaico-item:hover :global(img),
  .mosaico-item:focus-visible :global(img) {
    scale: 1.03;
  }

  @media (max-width: 820px) {
    .mosaico {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto auto;
      aspect-ratio: auto;
      max-height: none;
    }

    .mosaico-item:first-child {
      grid-column: 1 / -1;
      grid-row: auto;
      aspect-ratio: 4 / 5;
    }

    .mosaico-item:not(:first-child) {
      aspect-ratio: 1;
    }
  }

  /* ---- Descrição + ficha ---- */
  .conteudo {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(280px, 1fr);
    gap: var(--space-6);
    align-items: start;
    margin-bottom: var(--space-7);
  }

  .descricao :global(p) {
    margin-bottom: var(--space-3);
  }

  .descricao :global(p:first-child em) {
    color: var(--text-secondary);
    font-size: 15px;
  }

  .descricao :global(h2),
  .descricao :global(h3) {
    margin-block: var(--space-4) var(--space-2);
  }

  .specs-painel {
    background: var(--surface);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-m);
    padding: var(--space-4);
    box-shadow: var(--shadow);
    position: sticky;
    top: var(--space-3);
  }

  .specs-titulo {
    margin-bottom: var(--space-3);
    color: var(--secondary);
  }

  .specs {
    display: grid;
    gap: var(--space-3);
  }

  .spec dt {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-secondary);
    margin-bottom: 2px;
  }

  .spec dd {
    font-weight: 500;
  }

  .spec:not(:last-child) {
    border-bottom: 1px solid var(--border-light);
    padding-bottom: var(--space-3);
  }

  @media (max-width: 900px) {
    .conteudo {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    .specs-painel {
      position: static;
    }
  }

  /* ---- Extras ---- */
  .extras {
    margin-bottom: var(--space-7);
  }

  .extras-titulo {
    margin-bottom: var(--space-4);
  }

  .extras-grelha {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .extra {
    padding: 0;
    background: var(--cream);
    border: 2px solid transparent;
    border-radius: 24px;
    overflow: clip;
    cursor: zoom-in;
    width: 180px;
    aspect-ratio: 1;
    transition: border-color 0.25s ease, scale 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .extra:hover,
  .extra:focus-visible {
    scale: 1.03;
    border-color: var(--background-dark);
  }

  .extra :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 640px) {
    .extra {
      width: calc(50% - var(--space-3) / 2);
    }
  }

  .rodape-navegacao {
    display: flex;
    justify-content: center;
    padding-block: var(--space-3) var(--space-4);
  }

  @media (prefers-reduced-motion: reduce) {
    .mosaico-item:hover :global(img),
    .extra:hover {
      scale: none;
    }
  }
</style>
