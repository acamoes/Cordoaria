---
import { getCollection, render } from 'astro:content';
import { getImage, Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Lightbox from '../../components/Lightbox.astro';
import { withBase, TIPO_LABEL } from '../../lib/utils';

export async function getStaticPaths() {
  const guitarras = await getCollection('guitarras');
  return guitarras.map((g) => ({ params: { slug: g.id }, props: { guitarra: g } }));
}

const { guitarra } = Astro.props;
const { nome, marca, modelo, tipo, anoAquisicao, fotos, extras, specs } = guitarra.data;
const { Content } = await render(guitarra);

const principais = [fotos.foto1, fotos.foto2, fotos.foto3, fotos.foto4];
const todas = [...principais, ...extras];

// Versões grandes para o lightbox
const grandes = await Promise.all(
  todas.map((f) => getImage({ src: f, width: 1800, format: 'webp', quality: 82 }))
);
const fotosLightbox = grandes.map((img, i) => ({
  src: img.src,
  alt:
    i < 4
      ? `Foto ${i + 1} da guitarra ${nome}`
      : `Foto extra ${i - 3} da guitarra ${nome}`,
}));

// Hero = foto 1 (índice 0). Miniaturas = todas as fotos (incluindo a foto 1
// como primeira), cada uma com o índice que abre a foto no lightbox.
const miniaturas = todas.map((foto, i) => ({ foto, i }));

const marcaModelo = [marca, modelo].filter(Boolean).join(' ');

const specsLista: [string, string][] = (
  [
    ['Ano de aquisição', String(anoAquisicao)],
    ['Corpo', specs.corpo],
    ['Tampo', specs.tampo],
    ['Braço', specs.braco],
    ['Escala', specs.escala],
    ['Captadores', specs.captadores],
    ['País de origem', specs.pais],
    ['N.º de série', specs.numeroSerie],
  ] as [string, string | undefined][]
).filter((par): par is [string, string] => Boolean(par[1]));

const descricaoMeta = `${nome}${marcaModelo ? ` — ${marcaModelo}` : ''} · ${TIPO_LABEL[tipo]}, adquirida em ${anoAquisicao}.`;
const ogImage = Astro.site ? new URL(grandes[0]!.src, Astro.site).href : undefined;
---

<Base title={nome} description={descricaoMeta} ogImage={ogImage}>
  <nav class="voltar reveal" aria-label="Voltar">
    <a href={withBase('/')} class="voltar-link">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
        <path d="M14 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      Galeria
    </a>
  </nav>

  <article class="produto">
    {/* ---- Bloco superior: categoria + título + marca ---- */}
    <header class="info-top">
      <p class="caption categoria reveal">
        <span class="categoria-tipo">{TIPO_LABEL[tipo]}</span>
        <span aria-hidden="true">·</span>
        <span>Adquirida em {anoAquisicao}</span>
      </p>
      <h1 class="titulo reveal" style="--reveal-delay: 70ms">{nome}</h1>
      {
        marcaModelo && (
          <p class="marca-modelo text-secondary reveal" style="--reveal-delay: 140ms">
            {marcaModelo}
          </p>
        )
      }
    </header>

    {/* ---- Media: foto 1 em destaque + tira de miniaturas ---- */}
    <div class="media">
      <button
        class:list={['hero', 'reveal', { recortada: fotos.foto1.format === 'png' }]}
        style="--reveal-delay: 120ms"
        type="button"
        data-lightbox="0"
        aria-label={`Ampliar foto 1 da ${nome}`}
      >
        <Image
          src={fotos.foto1}
          alt={`Foto 1 da guitarra ${nome}`}
          widths={[600, 900, 1400]}
          sizes="(max-width: 900px) 94vw, 64vw"
          loading="eager"
          transition:name={`foto-hero-${guitarra.id}`}
        />
      </button>

      <div class="miniaturas reveal" style="--reveal-delay: 200ms" role="group" aria-label="Mais fotos">
        {
          miniaturas.map(({ foto, i }) => (
            <button
              class:list={['mini', { recortada: foto.format === 'png' }]}
              type="button"
              data-lightbox={i}
              aria-label={`Ampliar foto ${i + 1} da ${nome}`}
            >
              <Image
                src={foto}
                alt={`Foto ${i + 1} da guitarra ${nome}`}
                widths={[220, 400]}
                sizes="(max-width: 900px) 28vw, 150px"
                loading="lazy"
              />
            </button>
          ))
        }
      </div>
    </div>

    {/* ---- Bloco inferior: descrição + ficha + CTA ---- */}
    <div class="info-bottom">
      <section class="descricao reveal" aria-label="Descrição">
        <Content />
      </section>

      {
        specsLista.length > 0 && (
          <section class="ficha reveal" style="--reveal-delay: 90ms" aria-label="Especificações">
            <h2 class="ficha-titulo">Ficha</h2>
            <dl class="specs">
              {specsLista.map(([rotulo, valor]) => (
                <div class="spec">
                  <dt class="caption">{rotulo}</dt>
                  <dd>{valor}</dd>
                </div>
              ))}
            </dl>
          </section>
        )
      }

      <div class="acoes reveal" style="--reveal-delay: 140ms">
        <button class="btn btn-primary" type="button" data-lightbox="0">
          Ver todas as fotos
        </button>
        <a class="btn btn-secondary" href={withBase('/')}>Voltar à galeria</a>
      </div>
    </div>
  </article>

  <Lightbox fotos={fotosLightbox} />
</Base>

<style>
  .voltar {
    margin-bottom: var(--space-4);
  }

  .voltar-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }

  .voltar-link:hover {
    color: var(--text);
  }

  /* ---- Grelha de produto: info à esquerda, media à direita ---- */
  .produto {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    grid-template-rows: auto 1fr;
    grid-template-areas:
      'top    media'
      'bottom media';
    gap: var(--space-5) var(--space-7);
    align-items: start;
    padding-bottom: var(--space-7);
  }

  .info-top {
    grid-area: top;
  }

  .media {
    grid-area: media;
    position: sticky;
    top: var(--space-4);
  }

  .info-bottom {
    grid-area: bottom;
    max-width: 52ch;
  }

  /* ---- Info superior ---- */
  .categoria {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
  }

  .categoria-tipo {
    color: var(--secondary);
    font-weight: 500;
  }

  .titulo {
    font-size: clamp(40px, 5.5vw, 64px);
  }

  .marca-modelo {
    font-size: 20px;
    margin-top: var(--space-3);
  }

  /* ---- Media ---- */
  .hero {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: var(--background-dark);
    border-radius: var(--radius-l);
    overflow: clip;
    cursor: zoom-in;
    aspect-ratio: 4 / 3;
  }

  .hero :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: scale 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero:hover :global(img),
  .hero:focus-visible :global(img) {
    scale: 1.02;
  }

  /* Foto recortada (PNG transparente): a guitarra é mostrada INTEIRA, mas o
     hero "sangra" (full-bleed) até à borda interior direita da .frame, para o
     braço tocar a moldura castanha escura da página. A margem-direita negativa
     alarga o hero para lá da coluna; o overflow:clip da .frame corta na borda
     arredondada. object-position: right alinha a guitarra à direita. */
  .hero.recortada {
    background: transparent;
    aspect-ratio: 3 / 2;
    max-height: min(78vh, 680px);
    /* Alarga o hero para lá da coluna, até à borda interior direita da .frame
       (o botão tem width:100% explícito, por isso alarga-se a largura em vez de
       usar margem negativa). O overflow:clip da .frame corta na borda. */
    --bleed-right: calc(
      var(--page-margin) +
        max(0px, (100vw - 2 * var(--frame-margin) - var(--max-width)) / 2)
    );
    width: calc(100% + var(--bleed-right));
  }

  .hero.recortada :global(img) {
    object-fit: contain;
    object-position: right center;
    padding: 0;
  }

  .miniaturas {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-3);
    overflow-x: auto;
    padding-bottom: var(--space-1);
    scrollbar-width: thin;
  }

  .mini {
    flex: 0 0 auto;
    width: clamp(84px, 12vw, 150px);
    aspect-ratio: 1;
    padding: 0;
    background: #ffffff;
    border: 2px solid transparent;
    border-radius: var(--radius-m);
    overflow: clip;
    cursor: zoom-in;
    transition: border-color 0.25s ease, scale 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mini:hover,
  .mini:focus-visible {
    scale: 1.03;
    border-color: var(--secondary);
  }

  .mini :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mini.recortada :global(img) {
    object-fit: contain;
    padding: 8%;
  }

  /* ---- Info inferior: descrição + ficha + ações ---- */
  .descricao :global(p) {
    margin-bottom: var(--space-3);
  }

  .descricao :global(p:first-child em) {
    color: var(--text-secondary);
    font-size: 15px;
  }

  .descricao :global(h2),
  .descricao :global(h3) {
    margin-block: var(--space-4) var(--space-2);
  }

  .ficha {
    margin-top: var(--space-5);
    border-top: 1px solid var(--border);
    padding-top: var(--space-4);
  }

  .ficha-titulo {
    font-size: 24px;
    color: var(--secondary);
    margin-bottom: var(--space-3);
  }

  .specs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3) var(--space-4);
  }

  .spec dt {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-secondary);
    margin-bottom: 2px;
  }

  .spec dd {
    font-weight: 500;
  }

  .acoes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  /* ---- Responsivo: empilha título → media → descrição/ficha/ações ---- */
  @media (max-width: 900px) {
    .produto {
      grid-template-columns: 1fr;
      grid-template-areas:
        'top'
        'media'
        'bottom';
      gap: var(--space-5);
    }

    .media {
      position: static;
    }

    .info-bottom {
      max-width: none;
    }
  }

  @media (max-width: 560px) {
    .hero {
      aspect-ratio: 4 / 4.4;
    }

    .specs {
      grid-template-columns: 1fr;
    }

    .acoes .btn {
      flex: 1 1 auto;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero:hover :global(img),
    .mini:hover {
      scale: none;
    }
  }
</style>
