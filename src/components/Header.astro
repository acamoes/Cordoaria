---
import { withBase } from '../lib/utils';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="logo" href={withBase('/')} aria-label="Cordoaria — início">
      <svg
        class="logo-mark"
        viewBox="0 0 32 32"
        width="30"
        height="30"
        aria-hidden="true"
        fill="none"
      >
        {/* Palheta (plectro) minimalista, stroke 2px */}
        <path
          d="M16 29C11 24 5 18.5 5 11.5 5 6.8 9.8 3 16 3s11 3.8 11 8.5C27 18.5 21 24 16 29Z"
          stroke="currentColor"
          stroke-width="2"
          stroke-linejoin="round"
        />
        <circle cx="16" cy="12" r="3" stroke="currentColor" stroke-width="2" />
      </svg>
      <span class="logo-text">Cordoaria</span>
    </a>

    <div class="header-right">
      <nav aria-label="Navegação principal">
        <a class="nav-link" href={withBase('/')}>Galeria</a>
      </nav>
      <a
        class="github-link"
        href="https://github.com/acamoes/Cordoaria"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Repositório no GitHub"
        title="Ver o código no GitHub"
      >
        <svg viewBox="0 0 16 16" width="20" height="20" aria-hidden="true" fill="currentColor">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
          />
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border-light);
    background: var(--background);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-3);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--text);
  }

  .logo-mark {
    color: var(--secondary);
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: 30px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
    padding-top: 3px; /* compensa a métrica alta da Bebas */
  }

  .nav-link {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text-secondary);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-pill);
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--text);
    background: var(--border-light);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-pill);
    color: var(--text);
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .github-link:hover {
    color: var(--secondary);
    background: var(--border-light);
  }
</style>
